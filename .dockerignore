# =============================================================================
# Docker ignore file - exclude unnecessary files from build context
# =============================================================================

# Dependencies (will be installed in container)
node_modules
*/node_modules

# Git
.git
.gitignore

# IDE and editor files
.vscode
.cursor
.idea
*.swp
*.swo

# Environment files (should be passed via env vars or secrets)
.env
.env.local
.env.*.local

# Build outputs (will be built in container)
packages/mini-app/dist

# Development files
.dmux-hooks
.dev.log
*.log

# Documentation (not needed in runtime)
docs
*.md
!packages/*/README.md

# Test files
*.test.ts
*.spec.ts
__tests__
coverage

# OS files
.DS_Store
Thumbs.db

# Drizzle migrations (schema is pushed directly)
packages/bot/drizzle

# SQLite database files (should be mounted as volume)
*.db
*.db-journal
*.db-wal
*.db-shm
data/

# Misc
*.tgz
*.tar.gz
.npmrc
.yarnrc
