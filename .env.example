# When true, allow self-matching (dev/testing only)
DEV=false

BOT_TOKEN=your_telegram_bot_token
# Comma-separated Telegram user IDs to receive rate provider alerts
ADMIN_IDS=123456789,987654321
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=openai/gpt-4o-mini
DB_FILE_NAME=./data/hawala.db
TRUSTED_GROUP_IDS=-1001234567890,-1009876543210
# Optional topic filter map: chatId:topicId,topicId;chatId:topicId
CHAT_TO_TOPICS=-1001234567890:10,12;-1009876543210:5
MESSAGE_BATCH_SIZE=5
# Optional timeout for incomplete batches (ms)
MESSAGE_BATCH_FLUSH_MS=15000
# Skip sending batch to LLM if new messages arrived meanwhile (batch is put back, no messages lost)
SKIP_BATCH_ON_NEW_MESSAGE=false
MINI_APP_URL=https://YOUR_DOMAIN/app
BOT_USERNAME=HawalaExchangeBot

# Rate limiting (anti-fraud)
RATE_LIMIT_DAILY_OFFERS=5
RATE_LIMIT_MONTHLY_OFFERS=10

# Cleanup old offers (days)
OFFER_MAX_AGE_DAYS=30
