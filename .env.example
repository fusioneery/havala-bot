# =============================================================================
# Halwa Bot - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------

# [REQUIRED] Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token

# [REQUIRED] OpenRouter API Key for LLM parsing
# Get one at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key

# OpenRouter model to use (default: openai/gpt-4o-mini)
# Recommended models: openai/gpt-4o-mini, anthropic/claude-3-haiku
OPENROUTER_MODEL=openai/gpt-4o-mini

# [REQUIRED] Public URL where mini-app is accessible
# For Railway: https://your-app.up.railway.app
# For Coolify: https://your-domain.com
MINI_APP_URL=https://YOUR_DOMAIN

# Bot username (without @, default: HawalaExchangeBot)
BOT_USERNAME=HawalaExchangeBot

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3000)
# Railway/Coolify will set this automatically
PORT=3000

# Environment mode
NODE_ENV=production

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# SQLite database file path
# For Docker: /app/data/hawala.db (maps to volume)
# For local dev: ./data/hawala.db
DB_FILE_NAME=/app/data/hawala.db

# -----------------------------------------------------------------------------
# Telegram Groups Configuration
# -----------------------------------------------------------------------------

# [REQUIRED] Comma-separated Telegram group IDs to monitor
# Get group ID: add @userinfobot to group, it will show the ID
# Supergroups start with -100
TRUSTED_GROUP_IDS=-1001234567890,-1009876543210

# Optional: Filter by specific topics within groups
# Format: chatId:topicId,topicId;chatId:topicId
# Example: -1001234567890:10,12;-1009876543210:5
CHAT_TO_TOPICS=

# -----------------------------------------------------------------------------
# Admin Configuration
# -----------------------------------------------------------------------------

# Comma-separated Telegram user IDs for admin alerts
# Admins receive rate provider alerts and error notifications
ADMIN_IDS=123456789

# -----------------------------------------------------------------------------
# Message Processing
# -----------------------------------------------------------------------------

# Number of messages to batch before sending to LLM (default: 5)
MESSAGE_BATCH_SIZE=5

# Timeout for incomplete batches in milliseconds (default: 15000)
MESSAGE_BATCH_FLUSH_MS=15000

# Skip batch if new messages arrive (put batch back, default: false)
SKIP_BATCH_ON_NEW_MESSAGE=false

# -----------------------------------------------------------------------------
# Rate Limiting (Anti-fraud)
# -----------------------------------------------------------------------------

# Maximum offers per user per day (default: 5)
RATE_LIMIT_DAILY_OFFERS=5

# Maximum offers per user per month (default: 10)
RATE_LIMIT_MONTHLY_OFFERS=10

# -----------------------------------------------------------------------------
# Cleanup
# -----------------------------------------------------------------------------

# Days before offers are auto-deleted (default: 30)
OFFER_MAX_AGE_DAYS=30

# -----------------------------------------------------------------------------
# Optional Services
# -----------------------------------------------------------------------------

# Open Exchange Rates API key for fiat exchange rates
# Get one at: https://openexchangerates.org
OPENEXCHANGERATES_API_KEY=

# Custom template for writing offers
# Available placeholders: {TAKE_AMOUNT}, {TAKE_CURRENCY}, {TAKE_PAYMENT_METHOD},
#                         {GIVE_AMOUNT}, {GIVE_CURRENCY}, {GIVE_PAYMENT_METHOD}
WRITE_OFFER_TEXT=

# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------

# Enable dev mode (allows self-matching for testing)
# NEVER set to true in production!
DEV=false
